---
/**
 * Homepage
 * 
 * Landing page with hero section and three equal project cards.
 */

import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Card from '../components/Card.astro';
import Footer from '../components/Footer.astro';
import { projectLinks, siteProjects } from '../config/links';
---

<Base>
  <Nav />
  
  <main>
    <section class="hero container">
      <img 
        src="/hispanistica-logo.png" 
        alt="Hispanistica Logo" 
        class="logo logo--home"
        style="margin: 0 auto var(--space-6);"
      />
      <p class="hero__text">Hispanistica documents Digital Humanities projects in Hispanic linguistics at Philipps University of Marburg, highlighting their technical foundations, versioned development workflows, and adherence to FAIR principles. It provides an overview of research infrastructures, corpora, and digital teaching tools developed by <a href={projectLinks.general.felixTacke} target="_blank" rel="noopener noreferrer">Felix Tacke</a>.</p>
    </section>
    
    <section class="container">
      <div class="card-grid">
        {siteProjects.map(project => (
          <Card 
            title={project.title}
            logoSrc={project.logoSrc}
            logoAlt={project.logoAlt}
            description={project.description}
            href={project.href}
          />
        ))}
      </div>
    </section>

  </main>
  
  <Footer />
</Base>
